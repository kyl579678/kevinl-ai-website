# ────────────────────────────────────────────────────────
# Kevin's AI Lab — Caddy 反向代理設定
# ────────────────────────────────────────────────────────
# 安裝方式（Windows）：
#   1. 下載 Caddy: https://caddyserver.com/download
#   2. 把 caddy.exe 放到 C:\caddy\
#   3. 把這個 Caddyfile 放到 C:\caddy\
#   4. 終端機執行: cd C:\caddy && caddy run
#
# 開機自動啟動（Windows）：
#   建議用 NSSM 或 Windows 工作排程器設定開機執行
# ────────────────────────────────────────────────────────

# ── Hub 入口（kevinl-ai.com）─────────────────────────
# Caddy 直接服務靜態 HTML，port 5000 是 Hub 的 HTTP 服務
# 注意：Hub 靜態頁需要另外啟動一個簡單 HTTP server
# 例如：python3 -m http.server 5000 --directory C:\caddy\hub
kevinl-ai.com {
    root * C:\caddy\hub
    file_server
    encode gzip
    log {
        output file C:\caddy\logs\hub.log
    }
}

# ── Defect iDoctor（idoctor.kevinl-ai.com）──────────
# 轉發到 WSL 裡跑的 Defect iDoctor FastAPI 服務
idoctor.kevinl-ai.com {
    reverse_proxy localhost:8080
    log {
        output file C:\caddy\logs\idoctor.log
    }
}

# ── OpenClaw Gateway（openclaw.kevinl-ai.com）────────
# 轉發到 WSL 裡跑的 OpenClaw Gateway
# 先在 WSL 把 OpenClaw port 改成 9000：
#   openclaw config set gateway.port 9000
#   openclaw gateway restart
openclaw.kevinl-ai.com {
    reverse_proxy localhost:9000
    log {
        output file C:\caddy\logs\openclaw.log
    }
}

# ── PM Assistant（pm.kevinl-ai.com）───────────────────
# 施工中，未來可對接其他服務
# pm.kevinl-ai.com {
#     reverse_proxy localhost:9100
# }

# ── 全域設定 ────────────────────────────────────────
{
    email kyl579678@gmail.com
    admin off
    auto_https off
}

# HTTP → HTTPS 強制重導向（Cloudflare 已終止 SSL 時改為 off）
http_port 80
https_port 443
